# Security
SECRET_KEY=replace-with-a-long-random-secret
ADMIN_SECRET_KEY=replace-with-a-different-long-random-secret

# Database (recommended: change these defaults for your own environment)
DATABASE_URL=postgresql+asyncpg://gameday:gameday_secret@localhost:5432/gameday
SYNC_DATABASE_URL=postgresql+psycopg2://gameday:gameday_secret@localhost:5432/gameday
POSTGRES_DB=gameday
POSTGRES_USER=gameday
POSTGRES_PASSWORD=gameday_secret
DATABASE_URL_DOCKER=postgresql+asyncpg://gameday:gameday_secret@db:5432/gameday
SYNC_DATABASE_URL_DOCKER=postgresql+psycopg2://gameday:gameday_secret@db:5432/gameday

# Redis (overridden by docker-compose)
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0

# Public URLs used by frontend in browser (recommended: change localhost to your server IPv4 when deploying)
API_URL=http://localhost
WS_URL=ws://localhost

# CORS - comma separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT settings
ACCESS_TOKEN_EXPIRE_HOURS=24
ADMIN_TOKEN_EXPIRE_HOURS=8

# Default admin account (auto-created on first startup)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin1234
DEFAULT_ADMIN_NAME=Admin

# Rate limiting (requests per minute)
LOGIN_RATE_LIMIT=10

# Scoring worker
CHALLENGE_REQUEST_TIMEOUT_MS=5000
MAX_SCORING_WORKERS=10
