# Security
SECRET_KEY=replace-with-a-long-random-secret
ADMIN_SECRET_KEY=replace-with-a-different-long-random-secret

# Database (overridden by docker-compose)
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@localhost:5432/<db_name>
SYNC_DATABASE_URL=postgresql+psycopg2://<db_user>:<db_password>@localhost:5432/<db_name>
POSTGRES_DB=<db_name>
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
DATABASE_URL_DOCKER=postgresql+asyncpg://<db_user>:<db_password>@db:5432/<db_name>
SYNC_DATABASE_URL_DOCKER=postgresql+psycopg2://<db_user>:<db_password>@db:5432/<db_name>

# Redis (overridden by docker-compose)
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0

# CORS - comma separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT settings
ACCESS_TOKEN_EXPIRE_HOURS=24
ADMIN_TOKEN_EXPIRE_HOURS=8

# Default admin account (auto-created on first startup)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace-with-strong-admin-password
DEFAULT_ADMIN_NAME=Admin

# Rate limiting (requests per minute)
LOGIN_RATE_LIMIT=10

# Scoring worker
CHALLENGE_REQUEST_TIMEOUT_MS=5000
MAX_SCORING_WORKERS=10
